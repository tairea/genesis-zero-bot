# Required: OpenRouter API key for LLM extraction
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# SurrealDB password (default: root)
SURREAL_PASS=your-surreal-password

# Optional: override the extraction model (default: google/gemini-3.1-flash-lite-preview)
# EXTRACTION_MODEL=google/gemini-3.1-flash-lite-preview
